# --- 데이터 자산: 데모용 1권(괴물 가족의 초대)만 포함 ---

# character 폴더: 기본 제외 후 데모 책만 허용
character/*
!character/리딩토탈_72개월_내지_괴물 가족의 초대_220608_ISBN/
!character/txt/

# txt 폴더: 072 월령의 데모 책 txt만 허용
character/txt/*
!character/txt/072/
character/txt/072/*
!character/txt/072/리딩토탈_72개월_내지_괴물 가족의 초대_220608_ISBN.txt

# BGM 폴더: 데모용 2개만 포함
BGM/*
!BGM/19/
!BGM/110/

# 출력물 / 임시
out/
output/
*.mp4
*.wav
*.mp3
*.m4a
!BGM/**/*.m4a
!BGM/**/*.mp3
!BGM/**/*.wav
